        { "id": "api",       "label": "API Gateway",         "type": "service", "col": 8, "row": 1 },
        { "id": "app",       "label": "App Services",        "type": "service", "col": 4, "row": 4 },
        { "id": "backend",   "label": "Backend Services",    "type": "service", "col": 8, "row": 4 },
        { "id": "dc",        "label": "Data Center",         "type": "server",  "col": 5, "row": 4 },
        { "id": "cloud-compute", "label": "Cloud Compute",   "type": "server",  "col": 7, "row": 4 },
        { "id": "ai",        "label": "AI / ML Services",    "type": "service", "col": 8, "row": 3 },
        { "id": "email",     "label": "Cisco Secure Email",  "type": "security","col": 3, "row": 2 }
      ]
    },
    {
      "id": "network-enforcement",
