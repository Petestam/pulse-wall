        { "id": "fw-internal",  "label": "Cisco Secure Firewall (Internal)",  "type": "security", "col": 2, "row": 4 },
        { "id": "umbrella",     "label": "Cisco Umbrella",                    "type": "security", "col": 9, "row": 1 },
        { "id": "secure-access","label": "Cisco Secure Access (SASE)",        "type": "security", "col": 1, "row": 3 },
        { "id": "duo",          "label": "Cisco Duo (MFA)",                   "type": "security", "col": 4, "row": 1 },
        { "id": "secure-endpoint","label": "Cisco Secure Endpoint",           "type": "security", "col": 9, "row": 4 },
        { "id": "sna",          "label": "Cisco Secure Network Analytics",    "type": "security", "col": 9, "row": 2 },
        { "id": "ai-defense",   "label": "Cisco AI Defense",                  "type": "security", "col": 9, "row": 3 },
        { "id": "sdwan",        "label": "Cisco Catalyst SD-WAN",             "type": "network",  "col": 2, "row": 3 },
