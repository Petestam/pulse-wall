        { "id": "iot-ot",       "label": "Cisco IoT / Industrial","type": "endpoint","col": 8, "row": 0 },
        { "id": "edge-devices", "label": "Edge Compute / Kiosks","type": "endpoint", "col": 3, "row": 5 },
        { "id": "multi-cloud",  "label": "Hybrid / Multi-Cloud","type": "network",   "col": 8, "row": 5 },
        { "id": "dmz",          "label": "DMZ / Ingress",       "type": "network",   "col": 1, "row": 1 }
      ]
    },
    {
      "id": "external",
      "label": "External",
      "description": "Users, partners, SaaS, and external threats at the perimeter",
      "nodes": [
        { "id": "internet-users", "label": "Internet Users",      "type": "external", "col": 0, "row": 1 },
        { "id": "remote-users",   "label": "Remote / Mobile Users","type": "external", "col": 0, "row": 3 },
