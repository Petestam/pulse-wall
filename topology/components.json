{
  "id": "pulse-wall-enterprise-topology",
  "name": "Enterprise Topology Master",
  "purpose": "Concentric enterprise topology for 12×5 LED wall",
  "references": {
    "folder": "topology/references/",
    "documents": [
      {
        "file": "Anatomy of an Attack — React2Shell.docx",
        "role": "Attack path, ingress/lateral/crown narrative, node naming"
      },
      {
        "file": "React2Shell.md",
        "role": "Nine-step React2Shell attack flow (ADC → AI → IPS → Nexus → RCE → FW → XDR → ES)"
      },
      {
        "file": "Pulse Wall SOW-Ext.docx",
        "role": "Scope, modes, scenario counts, wall behavior"
      }
    ],
    "note": "Reconcile labels and edges here plus routes in topology/routes.json before client sign-off."
  },
  "display": {
    "canvas": { "widthUnits": 120, "heightUnits": 60, "aspectHint": "2:1 wall (e.g. 12x5 tiles)" },
    "grid": { "cols": 12, "rows": 5, "note": "Optional overlay only; node positions are not locked to this grid." },
    "layout": "concentric-trust",
    "layoutModes": {
      "concentric-trust": "Seed nodes in concentric trust rings and refine with constrained edge forces.",
      "grid": "Use col/row from each node as tile centers (legacy / LED mapping)."
    }
  },
  "styleGuide": {
    "solid": "Primary network, service, or dependency connection",
    "dashed": "Trust boundary, segmented relationship, or controlled handoff",
    "dotted": "Telemetry, monitoring, or logical association",
    "trustBoundary": "Edges with trustBoundary:true use an accent stroke + midLabel; zoneHalos tint trust zones and trustMembranes mark explicit crossings."
  },
  "zoneHalos": [
    {
      "id": "zone-core",
      "ringId": "core",
      "label": "Core Assets",
      "padding": 1.6,
      "rx": 1.6,
      "fill": "rgba(34, 197, 94, 0.09)",
      "stroke": "rgba(74, 222, 128, 0.24)"
    },
    {
      "id": "zone-soc",
      "ringId": "soc-platform",
      "label": "SOC / Ops Platform",
      "padding": 1.45,
      "rx": 1.45,
      "fill": "rgba(59, 130, 246, 0.08)",
      "stroke": "rgba(96, 165, 250, 0.22)"
    },
    {
      "id": "zone-app",
      "ringId": "application",
      "label": "Application Services",
      "padding": 1.35,
      "rx": 1.35,
      "fill": "rgba(99, 102, 241, 0.075)",
      "stroke": "rgba(129, 140, 248, 0.20)"
    },
    {
      "id": "zone-enforcement",
      "ringId": "network-enforcement",
      "label": "Network & Security",
      "padding": 1.35,
      "rx": 1.35,
      "fill": "rgba(239, 68, 68, 0.08)",
      "stroke": "rgba(248, 113, 113, 0.22)"
    },
    {
      "id": "zone-edge",
      "ringId": "enterprise-edge",
      "label": "Enterprise Edge",
      "padding": 1.3,
      "rx": 1.3,
      "fill": "rgba(14, 165, 233, 0.075)",
      "stroke": "rgba(56, 189, 248, 0.20)"
    },
    {
      "id": "zone-external",
      "ringId": "external",
      "label": "External",
      "padding": 1.2,
      "rx": 1.2,
      "fill": "rgba(148, 163, 184, 0.07)",
      "stroke": "rgba(148, 163, 184, 0.20)"
    }
  ],
  "trustMembranes": [
    {
      "id": "membrane-ai-backend",
      "from": "ai",
      "to": "backend",
      "label": "Trust boundary",
      "length": 5.2,
      "thickness": 0.78,
      "fill": "rgba(245, 158, 11, 0.24)",
      "stroke": "rgba(245, 158, 11, 0.58)",
      "strokeWidth": 0.12,
      "strokeDasharray": "0.48 0.36",
      "filter": "url(#membrane-glow)"
    }
  ],
  "rings": [
    {
      "id": "core",
      "label": "Core Assets",
      "description": "Systems of record, identity authority, and highest-value enterprise assets",
      "nodes": [
        { "id": "identity",  "label": "Identity (AD / IdP)",     "type": "data",    "col": 5, "row": 2 },
        { "id": "core-data", "label": "Core Data",               "type": "data",    "col": 6, "row": 2 },
        { "id": "business",  "label": "Business Systems",        "type": "service", "col": 5, "row": 3 },
        { "id": "crown",     "label": "Crown Jewel Assets",      "type": "data",    "col": 6, "row": 3 }
      ]
    },
    {
      "id": "soc-platform",
      "label": "SOC / Operations Platform",
      "description": "Splunk and Cisco analytics brain — consumes telemetry from all rings, drives response",
      "nodes": [
        { "id": "splunk-es",  "label": "Splunk Enterprise Security", "type": "platform", "col": 4, "row": 2 },
        { "id": "splunk-obs", "label": "Splunk Observability Cloud", "type": "platform", "col": 7, "row": 2 },
        { "id": "cisco-xdr",  "label": "Cisco XDR",                  "type": "platform", "col": 4, "row": 3 },
        { "id": "splunk-soar","label": "Splunk SOAR",                "type": "platform", "col": 7, "row": 3 },
        { "id": "fabric",     "label": "Splunk Federated Search",         "type": "platform", "col": 5, "row": 1 },
        { "id": "talos",      "label": "Cisco Talos Intelligence",   "type": "platform", "col": 6, "row": 1 }
      ]
    },
    {
      "id": "application",
      "label": "Application Services",
